# ================================================================
# Vehicle Telemetry Platform — 환경변수 설정
# 이 파일을 복사해서 .env 로 만들고 실제 값을 채워넣으세요
# cp .env.example .env
# ================================================================

# ── MQTT 브로커 (Mosquitto) ──────────────────────────────────────
MQTT_PORT=1883
MQTT_TLS_PORT=8883

# ── Kafka ────────────────────────────────────────────────────────
KAFKA_PORT=9092

# ── InfluxDB (시계열 DB) ─────────────────────────────────────────
INFLUXDB_PORT=8086
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=change_me_influx_password
INFLUXDB_ORG=vehicle-telemetry
INFLUXDB_BUCKET=telemetry
INFLUXDB_TOKEN=change_me_influxdb_admin_token_min_32chars

# ── PostgreSQL (관계형 DB) ────────────────────────────────────────
POSTGRES_PORT=5432
POSTGRES_DB=telemetry
POSTGRES_USER=telemetry_user
POSTGRES_PASSWORD=change_me_postgres_password

# ── Redis (캐시 / Rate Limiting) ─────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# ── Spring Boot 백엔드 ───────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
INFLUXDB_URL=http://localhost:8086

# ── Grafana ──────────────────────────────────────────────────────
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme

# ── 이상 감지 모듈 ───────────────────────────────────────────────
ML_ENABLED=false
ML_MIN_SAMPLES=200
WEBHOOK_URL=

# ── Phase 4 TLS (인증서 생성 후 경로 설정) ───────────────────────
TLS_CA_CERT=
TLS_CLIENT_CERT=
TLS_CLIENT_KEY=

# ── 차량 시뮬레이터 ──────────────────────────────────────────────
VEHICLE_COUNT=3
PUBLISH_INTERVAL=1.0
ANOMALY_RATE=0.02

# ── Spring Boot API ──────────────────────────────────────────────
SERVER_PORT=8080
JWT_SECRET=change_me_jwt_secret_key_must_be_at_least_32_characters
JWT_EXPIRATION_MS=86400000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
RATE_LIMIT_RPM=60
